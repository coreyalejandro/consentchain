{
  "name": "claude-repo-template",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "format": "prettier -w .",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "verify": "bash ./scripts/verify.sh",
    "security": "bash ./scripts/security.sh",
    "sbom": "bash ./scripts/sbom.sh",
    "build": "tsc -p tsconfig.build.json",
    "start": "node ./dist/server.js",
    "dev": "node --watch --enable-source-maps ./dist/server.js"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@cyclonedx/cyclonedx-npm": "^1.14.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "supertest": "^7.0.0",
    "@types/supertest": "^2.0.16"
  },
  "dependencies": {
    "express": "^4.19.2",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0"
  }
}
